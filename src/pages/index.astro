				<span class="mt-1 text-xs font-semibold uppercase tracking-wider text-slate-600 sm:text-sm">YouTube Views</span>
				<div class="flex items-center justify-center flex-wrap gap-1 text-xs text-slate-400">
					<span>Source: YT</span>
					<div class="flex items-center">
						<span>(</span><a href="https://www.youtube.com/@FarhanHussain" target="_blank" rel="noopener noreferrer" class="hover:text-indigo-600 transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-2 rounded" aria-label="Source for Personal YouTube views">Personal</a>
						<span class="mx-0.5">&amp;</span>
						<a href="https://www.youtube.com/@SchoolofMachineLearning" target="_blank" rel="noopener noreferrer" class="hover:text-indigo-600 transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-2 rounded" aria-label="Source for ML YouTube views">ML</a><span>)</span>
					</div>
				</div>
			</div>
			<div class="flex min-h-32 flex-col items-center justify-center rounded-lg bg-indigo-50/80 p-4">
				<span class="text-3xl font-bold tracking-tight text-indigo-600 lg:text-4xl">20k+</span>
				<span class="mt-1 text-xs font-semibold uppercase tracking-wider text-slate-600 sm:text-sm">Subscribers</span>
				<div class="flex items-center justify-center flex-wrap gap-1 text-xs text-slate-400">
					<span>Source: YT</span>
					<div class="flex items-center">
						<span>(</span><a href="https://www.youtube.com/@FarhanHussain" target="_blank" rel="noopener noreferrer" class="hover:text-indigo-600 transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-2 rounded" aria-label="Source for Personal YouTube subscribers">Personal</a>
						<span class="mx-0.5">&amp;</span>
						<a href="https://www.youtube.com/@SchoolofMachineLearning" target="_blank" rel="noopener noreferrer" class="hover:text-indigo-600 transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-2 rounded" aria-label="Source for ML YouTube subscribers">ML</a><span>)</span>
					</div>
				</div>
			</div>
			<div class="flex min-h-32 flex-col items-center justify-center rounded-lg bg-cyan-50/80 p-4">
				<span class="text-3xl font-bold tracking-tight text-cyan-700 lg:text-4xl">18M+</span>
				<span class="mt-1 text-xs font-semibold uppercase tracking-wider text-slate-600 sm:text-sm">Pageviews</span>
				<a href="https://maypalo.com" target="_blank" rel="noopener noreferrer" class="text-xs text-slate-400 hover:text-indigo-600 transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-2 rounded" aria-label="Source for site pageviews">Source: Site analytics</a>
			</div>
		</div>
		<div class="mt-6 text-center">
