			<p class="text-xs text-slate-400 max-w-lg mx-auto leading-relaxed">
				* Metrics are approximate and pulled from platform analytics (YouTube Studio, newsletter platform, site analytics).
			</p>
		</div>
	</section>

	<script>
		const metricsCurrentMonth = document.getElementById('metrics-current-month');

		if (metricsCurrentMonth) {
			const currentMonth = new Intl.DateTimeFormat('en-US', {
				month: 'long',
				year: 'numeric',
			}).format(new Date());

			metricsCurrentMonth.textContent = `As of ${currentMonth}`;
		}
	</script>

	<!-- Courses Section -->
	<section class="mb-20 md:mb-24">
		<div class="mb-8">
